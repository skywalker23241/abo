<button class="back-to-top" type="button" aria-label="Back to top">
  <svg
    class="back-to-top__icon"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 256 256"
    aria-hidden="true"
    focusable="false"
  >
    <path
      d="M128 48l-72 72a8 8 0 1011.31 11.31L120 78.63V200a8 8 0 0016 0V78.63l52.69 52.68A8 8 0 10200 120z"
      fill="currentColor"></path>
  </svg>
  <span class="sr-only">Back to top</span>
</button>

<style>
  .back-to-top {
    position: fixed;
    right: max(1.5rem, calc((100vw - var(--content-width)) / 2 - 4rem));
    bottom: 1.5rem;
    z-index: 30;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 999px;
    background-color: color-mix(in srgb, var(--bg) 88%, transparent);
    color: var(--text-secondary);
    box-shadow: 0 0.35rem 1.4rem color-mix(in srgb, var(--text-primary) 10%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    cursor: pointer;
    opacity: 0;
    visibility: hidden;
    transform: translateY(0.5rem);
    pointer-events: none;
    transition:
      opacity 0.18s ease-out,
      transform 0.18s ease-out,
      color 0.15s ease-out,
      background-color 0.15s ease-out,
      border-color 0.15s ease-out,
      visibility 0.18s ease-out;
  }

  .back-to-top.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .back-to-top:hover {
    color: var(--text-primary);
    background-color: color-mix(in srgb, var(--bg) 94%, transparent);
  }

  .back-to-top__icon {
    width: 1.1rem;
    height: 1.1rem;
  }

  @media (max-width: 768px) {
    .back-to-top {
      right: 1.25rem;
      bottom: 1.25rem;
      width: 2.5rem;
      height: 2.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .back-to-top {
      transition: none;
      transform: none;
    }
  }
</style>

<script is:inline>
  ;(function () {
    const state = (window.__backToTopState ||= {
      installed: false
    })

    function setupBackToTop() {
      const button = document.querySelector('.back-to-top')
      if (!button || button.dataset.bound === 'true') return
      button.dataset.bound = 'true'

      const syncVisibility = () => {
        button.classList.toggle('is-visible', window.scrollY > 360)
      }

      const scrollToTop = () => {
        window.scrollTo({ top: 0, behavior: 'smooth' })
      }

      syncVisibility()
      button.addEventListener('click', scrollToTop)
      window.addEventListener('scroll', syncVisibility, { passive: true })

      document.addEventListener(
        'astro:before-swap',
        () => {
          button.removeEventListener('click', scrollToTop)
          window.removeEventListener('scroll', syncVisibility)
          button.dataset.bound = 'false'
        },
        { once: true }
      )
    }

    window.__setupBackToTop = setupBackToTop
    setupBackToTop()

    if (!state.installed) {
      state.installed = true
      document.addEventListener('astro:page-load', setupBackToTop)
    }
  })()
</script>
