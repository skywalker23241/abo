---
import { themeConfig } from '@/config'
const today = new Date()
---

<footer class="site-footer">
  <hr />
  <div class="footer-row">
    <span class="copyright">
      &copy; {today.getFullYear()} <a href="https://github.com/skywalker23241" target="_blank" rel="noopener noreferrer">{themeConfig.site.author}</a>
    </span>
    <div class="footer-links">
      <a href="/rss.xml" aria-label="RSS feed">rss</a>
      <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/deed.zh-hans">cc by-nc-sa</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    font-size: var(--font-size-s);
    color: var(--text-secondary);
  }

  .site-footer hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0 0 1rem 0;
  }

  .footer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-links {
    display: flex;
    gap: 0.85rem;
  }

  .site-footer a {
    color: var(--text-secondary);
    text-decoration: none;
    transition:
      color 0.15s ease-out,
      box-shadow 0.15s ease-out;
  }

  .site-footer a:hover {
    color: var(--text-primary);
    background-color: var(--selection);
  }
</style>
