---
import { themeConfig } from '@/config'
import BottomNav from '@/components/layout/BottomNav.astro'

interface NavLink {
  href: string
  label: string
}

interface Props {
  previousPostLink?: NavLink
  nextPostLink?: NavLink
}

const { previousPostLink, nextPostLink } = Astro.props
const today = new Date()
---

<footer class="site-footer">
  <BottomNav previousPostLink={previousPostLink} nextPostLink={nextPostLink} />
  <hr />
  <div class="footer-row">
    <span class="copyright">
      &copy; {today.getFullYear()} {themeConfig.site.author}
    </span>
    <div class="footer-links">
      <a href="/rss.xml" aria-label="RSS feed">rss</a>
      <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/deed.zh-hans">cc by-nc-sa</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4.5rem;
    font-size: var(--font-size-s);
    color: var(--text-secondary);
  }

  .site-footer hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0 0 1.05rem 0;
  }

  @media (max-width: 640px) {
    .site-footer {
      margin-top: 3.5rem;
    }
  }

  .footer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-links {
    display: flex;
    gap: 0.85rem;
  }

  @media (max-width: 420px) {
    .footer-row {
      justify-content: center;
      text-align: center;
    }

    .footer-links {
      justify-content: center;
      width: 100%;
    }
  }

  .footer-links a {
    color: var(--text-secondary);
    text-decoration: none;
    transition:
      color 0.15s ease-out,
      box-shadow 0.15s ease-out;
  }

  .footer-links a:hover {
    color: var(--text-primary);
    box-shadow: inset 0 -0.28em 0 color-mix(in srgb, var(--selection) 100%, transparent);
  }
</style>
