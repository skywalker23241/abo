---
import ThemeToggle from '@/components/ui/ThemeToggle.astro'
---

<header class="site-header">
  <nav class="site-nav" aria-label="Primary">
    <a class="site-brand" href="/" aria-label="Abo 主页">
      <img
        class="brand-logo brand-logo-light"
        src="/logo-light.png"
        alt="Abo"
        width="184"
        height="112"
      />
      <img
        class="brand-logo brand-logo-dark"
        src="/logo-dark.png"
        alt=""
        width="184"
        height="112"
      />
    </a>
    <div class="nav-actions">
      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    margin-top: -2.5rem;
    margin-bottom: 2.25rem;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    padding-top: 2.5rem;
    background-color: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    transition:
      background-color 0.18s ease-out,
      box-shadow 0.18s ease-out;
  }

  .site-header.is-scrolled {
    background-color: color-mix(in srgb, var(--bg) 92%, transparent);
    box-shadow: 0 0.35rem 1.4rem color-mix(in srgb, var(--text-primary) 7%, transparent);
  }

  .site-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    box-sizing: border-box;
    width: 100%;
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 1.5rem 0.85rem;
  }

  .site-brand {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    width: 5rem;
    height: 3.125rem;
    color: var(--text-primary);
    text-decoration: none;
  }

  .brand-logo {
    display: block;
    width: 5rem;
    height: auto;
    aspect-ratio: 8 / 5;
    object-fit: contain;
  }

  .brand-logo-dark {
    display: none;
  }

  :global(html.dark) .brand-logo-light {
    display: none;
  }

  :global(html.dark) .brand-logo-dark {
    display: block;
  }

  .nav-actions {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    flex: 0 0 auto;
  }

  .site-nav :global(astro-theme-toggle) {
    width: 20px;
    height: 20px;
    color: var(--text-secondary);
    display: inline-flex;
    transition: color 0.15s ease-out;
  }

  .site-nav :global(astro-theme-toggle:hover) {
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .site-header {
      margin-top: -1.75rem;
      margin-bottom: 1.75rem;
      padding-top: 1.75rem;
    }

    .site-brand {
      width: 4.5rem;
      height: 2.8125rem;
    }

    .brand-logo {
      width: 4.5rem;
    }

    .nav-actions {
      margin-left: auto;
    }
  }
</style>

<script>
  function setupHeaderScrollState() {
    const header = document.querySelector<HTMLElement>('.site-header')
    if (!header || header.dataset.scrollStateBound === 'true') return
    header.dataset.scrollStateBound = 'true'

    const syncScrolledState = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 12)
    }

    syncScrolledState()
    window.addEventListener('scroll', syncScrolledState, { passive: true })
    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', syncScrolledState)
    })
  }

  setupHeaderScrollState()
  document.addEventListener('astro:page-load', setupHeaderScrollState)
</script>
