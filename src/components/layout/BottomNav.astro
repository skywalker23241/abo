---
import { getNextNavLink, getPreviousNavLink } from '@/lib/navigation'

interface NavLink {
  href: string
  label: string
}

interface Props {
  previousPostLink?: NavLink
  nextPostLink?: NavLink
}

const { previousPostLink, nextPostLink } = Astro.props
const nextLink = getNextNavLink(Astro.url.pathname)
const previousLink = getPreviousNavLink(Astro.url.pathname)
const isPostNav = Boolean(previousPostLink || nextPostLink)
---

<nav class="bottom-nav" aria-label="Page navigation">
  {
    isPostNav ? (
      <div class="bottom-nav-inner post">
        {previousPostLink && (
          <a
            class="bottom-nav-link previous"
            href={previousPostLink.href}
            data-page-direction="previous"
            title={previousPostLink.label}
          >
            <span aria-hidden="true">←</span>
            上一篇
            <span class="post-nav-title">{previousPostLink.label}</span>
          </a>
        )}
        {nextPostLink && (
          <a
            class="bottom-nav-link next"
            href={nextPostLink.href}
            data-page-direction="next"
            title={nextPostLink.label}
          >
            <span class="post-nav-title">{nextPostLink.label}</span>
            下一篇
            <span aria-hidden="true">→</span>
          </a>
        )}
      </div>
    ) : (
      <div class="bottom-nav-inner">
        <a class="bottom-nav-link previous" href={previousLink.href} data-page-direction="previous">
          <span aria-hidden="true">←</span>
          {previousLink.label}
        </a>
        <a class="bottom-nav-link next" href={nextLink.href} data-page-direction="next">
          {nextLink.label}
          <span aria-hidden="true">→</span>
        </a>
      </div>
    )
  }
</nav>

<style>
  .bottom-nav {
    margin: 0 0 1.15rem;
  }

  .bottom-nav-inner {
    display: flex;
    justify-content: stretch;
    align-items: center;
    box-sizing: border-box;
    width: fit-content;
    max-width: calc(100vw - 3rem);
    margin: 0 auto;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--border) 82%, transparent);
    border-radius: 999px;
    background-color: color-mix(in srgb, var(--bg) 72%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 0.4rem 1.6rem color-mix(in srgb, var(--text-primary) 8%, transparent);
    transition:
      transform 0.16s ease-out,
      box-shadow 0.16s ease-out,
      border-color 0.16s ease-out;
  }

  .bottom-nav-inner:hover {
    border-color: color-mix(in srgb, var(--text-tertiary) 70%, transparent);
    box-shadow: 0 0.55rem 1.8rem color-mix(in srgb, var(--text-primary) 12%, transparent);
    transform: translateY(-0.12rem);
  }

  .bottom-nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    min-width: 4.6rem;
    min-height: 2rem;
    padding: 0.28rem 0.85rem;
    color: var(--text-primary);
    text-decoration: none;
    font-size: var(--font-size-s);
    font-weight: 600;
    line-height: 1.2;
    transition:
      transform 0.15s ease-out,
      background-color 0.15s ease-out;
  }

  .post-nav-title {
    display: inline-block;
    max-width: 0;
    opacity: 0;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    color: var(--text-secondary);
    font-weight: 500;
    transition:
      max-width 0.2s ease-out,
      opacity 0.15s ease-out;
  }

  .bottom-nav-inner.post .bottom-nav-link:hover .post-nav-title,
  .bottom-nav-inner.post .bottom-nav-link:focus-visible .post-nav-title {
    max-width: min(14rem, 42vw);
    opacity: 1;
  }

  .bottom-nav-link + .bottom-nav-link {
    border-left: 1px solid color-mix(in srgb, var(--border) 82%, transparent);
  }

  .bottom-nav-link:hover {
    background-color: color-mix(in srgb, var(--selection) 100%, transparent);
  }

  .bottom-nav-link.previous:hover {
    transform: translateX(-0.08rem);
  }

  .bottom-nav-link.next:hover {
    transform: translateX(0.08rem);
  }

  .bottom-nav-link:focus-visible {
    outline-offset: 0.2rem;
  }

  :global(html.page-turning-previous .layout-wrapper) {
    animation: page-turn-previous 0.26s ease-in both;
    transform-origin: 100% 50%;
  }

  :global(html.page-turning-next .layout-wrapper) {
    animation: page-turn-next 0.26s ease-in both;
    transform-origin: 0 50%;
  }

  @keyframes page-turn-previous {
    0% {
      opacity: 1;
      filter: blur(0);
      transform: perspective(900px) rotateY(0) translateX(0);
    }
    100% {
      opacity: 0.32;
      filter: blur(3px);
      transform: perspective(900px) rotateY(10deg) translateX(-1.25rem);
    }
  }

  @keyframes page-turn-next {
    0% {
      opacity: 1;
      filter: blur(0);
      transform: perspective(900px) rotateY(0) translateX(0);
    }
    100% {
      opacity: 0.32;
      filter: blur(3px);
      transform: perspective(900px) rotateY(-10deg) translateX(1.25rem);
    }
  }

  @media (max-width: 640px) {
    .bottom-nav {
      margin-bottom: 1rem;
    }

    .bottom-nav-link {
      min-width: 3.8rem;
      min-height: 1.9rem;
      padding: 0.22rem 0.55rem;
      font-size: 0.8rem;
    }

    .post-nav-title {
      display: none;
    }
  }

  @media (max-width: 360px) {
    .bottom-nav-inner {
      max-width: calc(100vw - 2rem);
    }

    .bottom-nav-link {
      min-width: 3.25rem;
      padding-right: 0.45rem;
      padding-left: 0.45rem;
      font-size: 0.76rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .bottom-nav-inner,
    .bottom-nav-link {
      transition: none;
    }

    :global(html.page-turning-previous .layout-wrapper),
    :global(html.page-turning-next .layout-wrapper) {
      animation: none;
    }
  }
</style>

<script is:inline>
  ;(function () {
    const state = (window.__bottomNavState ||= {
      installed: false
    })

    function clearBottomNavPageTurn() {
      document.documentElement.classList.remove('page-turning-previous', 'page-turning-next')
    }

    function setupBottomNavPageTurn() {
      const links = document.querySelectorAll('.bottom-nav-link')

      links.forEach((link) => {
        if (link.dataset.pageTurnBound === 'true') return
        link.dataset.pageTurnBound = 'true'

        link.addEventListener('click', (event) => {
          if (
            event.defaultPrevented ||
            event.metaKey ||
            event.ctrlKey ||
            event.shiftKey ||
            event.altKey ||
            link.target
          ) {
            return
          }

          const href = link.href
          if (!href || href === window.location.href) return

          const direction = link.dataset.pageDirection === 'previous' ? 'previous' : 'next'
          clearBottomNavPageTurn()
          document.documentElement.classList.add(`page-turning-${direction}`)
        })
      })
    }

    window.__setupBottomNavPageTurn = setupBottomNavPageTurn
    setupBottomNavPageTurn()

    if (!state.installed) {
      state.installed = true
      document.addEventListener('astro:page-load', setupBottomNavPageTurn)
      document.addEventListener('astro:before-swap', clearBottomNavPageTurn)
      document.addEventListener('astro:after-swap', clearBottomNavPageTurn)
    }
  })()
</script>
