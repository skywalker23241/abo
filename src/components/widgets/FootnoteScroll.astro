<script>
  let footnoteInitPending = false

  function bindFootnoteEvents() {
    const footnoteLinks = document.querySelectorAll('[data-footnote-ref], [data-footnote-backref]')

    footnoteLinks.forEach((link) => {
      if (link.dataset.footnoteScrollInit === '1') return
      link.dataset.footnoteScrollInit = '1'

      link.addEventListener('click', (e) => {
        e.preventDefault()
        const href = link.getAttribute('href')
        if (!href) return

        const target = document.querySelector(href)
        if (!target) return

        // Use fixed offset of 128px
        const offset = 128

        const targetPosition = target.getBoundingClientRect().top + window.scrollY - offset

        window.scrollTo({
          top: targetPosition
        })
      })
    })
  }

  function scheduleFootnoteEvents() {
    if (footnoteInitPending) return
    footnoteInitPending = true
    requestAnimationFrame(() => {
      footnoteInitPending = false
      bindFootnoteEvents()
    })
  }

  scheduleFootnoteEvents()
  document.addEventListener('astro:after-swap', scheduleFootnoteEvents)
  document.addEventListener('astro:page-load', scheduleFootnoteEvents)
  document.addEventListener('DOMContentLoaded', scheduleFootnoteEvents)
</script>
