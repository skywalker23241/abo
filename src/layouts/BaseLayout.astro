---
import { themeConfig } from '@/config'
import { ClientRouter } from 'astro:transitions'

import FaviconThemeSwitcher from '@/components/ui/FaviconThemeSwitcher.astro'
import BackToTop from '@/components/ui/BackToTop.astro'
import CopyCode from '@/components/ui/CopyCode.astro'
import GitHubCard from '@/components/ui/GitHubCard.astro'
import ImageOptimizer from '@/components/ui/ImageOptimizer.astro'
import ImageViewer from '@/components/ui/ImageViewer.astro'
import LinkCard from '@/components/ui/LinkCard.astro'
import NeoDBCard from '@/components/ui/NeoDBCard.astro'
import XPOST from '@/components/ui/XPOST.astro'
import GiscusLoader from '@/components/widgets/GiscusLoader.astro'
import GlimmPageTransition from '@/components/layout/GlimmPageTransition.astro'
import type { LayoutProps } from '@/types'

type Props = LayoutProps

const { type = 'page' } = Astro.props
const language = (themeConfig.site.language || 'en-US').replace('_', '-')
const fadeAnimation = themeConfig.general.fadeAnimation
const isPostLayout = type === 'post'
---

<html lang={language}>
  <head>
    <script is:inline>
      /* eslint-disable no-var */
      // Make customElements.define idempotent so component scripts that get
      // re-executed during view-transition navigations (e.g. astro-theme-toggle)
      // don't throw "already defined" on every navigation.
      ;(function () {
        if (window.__customElementsDefineGuarded) return
        window.__customElementsDefineGuarded = true
        var nativeDefine = customElements.define
        customElements.define = function (name, ...args) {
          if (customElements.get(name)) return
          return nativeDefine.call(customElements, name, ...args)
        }
      })()
    </script>
    <slot name="head" />
  </head>
  <body data-copy-code={themeConfig.post.copyCode ? 'enabled' : 'disabled'}>
    <FaviconThemeSwitcher />
    {isPostLayout && <GiscusLoader />}
    <BackToTop />
    <ImageOptimizer />
    <CopyCode />
    <GitHubCard />
    <XPOST />
    <NeoDBCard />
    {themeConfig.post.imageViewer && <ImageViewer />}
    {themeConfig.post.linkCard && <LinkCard />}
    {fadeAnimation && <GlimmPageTransition />}
    {fadeAnimation && <ClientRouter />}

    <div class="layout-wrapper">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  .layout-wrapper {
    display: flex;
    flex-direction: column;
    flex: 1;
  }
</style>
