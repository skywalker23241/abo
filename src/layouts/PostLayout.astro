---
import '@/styles/global.css'
import type { PostLayoutProps } from '@/types'
import MarkdownIt from 'markdown-it'
import FormattedDate from '@/components/widgets/FormattedDate.astro'
import FootnoteScroll from '@/components/widgets/FootnoteScroll.astro'
import BaseHead from '@/components/layout/BaseHead.astro'
import Header from '@/components/layout/Header.astro'
import Footer from '@/components/layout/Footer.astro'
import TableOfContents from '@/components/ui/TableOfContents.astro'
import ImageOptimizer from '@/components/ui/ImageOptimizer.astro'
import ImageViewer from '@/components/ui/ImageViewer.astro'
import GitHubCard from '@/components/ui/GitHubCard.astro'
import LinkCard from '@/components/ui/LinkCard.astro'
import NeoDBCard from '@/components/ui/NeoDBCard.astro'
import XPOST from '@/components/ui/XPOST.astro'
import CopyCode from '@/components/ui/CopyCode.astro'
import LikeButton from '@/components/widgets/LikeButton.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'

import { themeConfig } from '@/config'

const { title, displayTitle, pubDate, updatedDate, description, readingTime, toc } =
  Astro.props as PostLayoutProps

const postSlug = Astro.url.pathname.split('/').filter(Boolean).pop() || ''
const ogImage = `/open-graph/${postSlug}.png`
const postDescription = description || themeConfig.site.description
const md = new MarkdownIt({ html: false })
const headingHtml = displayTitle ? md.renderInline(displayTitle) : title
---

<BaseLayout
  title={`${title} · ${themeConfig.site.title}`}
  description={postDescription}
  type="post"
>
  <BaseHead
    title={`${title} · ${themeConfig.site.title}`}
    description={postDescription}
    ogImage={ogImage}
    pageType="article"
    publishedTime={pubDate}
    modifiedTime={updatedDate}
    slot="head"
  />
  <link rel="stylesheet" href="/katex.min.css" slot="head" />

  <Header />

  <main class="post-main">
    <article class="prose">
      {themeConfig.post.toc && <TableOfContents toc={toc} />}
      <header class="post-header">
        <h1 set:html={headingHtml} />
        <div class="post-meta">
          <FormattedDate date={pubDate} context="post" />
          {
            themeConfig.post.readingTime && readingTime && (
              <>
                <span class="meta-sep">·</span>
                <span class="reading-time">{readingTime.text}</span>
              </>
            )
          }
        </div>
      </header>
      <slot />
      <LikeButton slug={postSlug} />
    </article>
    <div id="giscus-container"></div>
  </main>

  <ImageOptimizer />
  <FootnoteScroll />
  <CopyCode />
  <GitHubCard />
  <XPOST />
  <NeoDBCard />
  {themeConfig.post.imageViewer && <ImageViewer />}
  {themeConfig.post.linkCard && <LinkCard />}
  {themeConfig.general.footer && <Footer />}
</BaseLayout>

<style>
  .post-main {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .post-header {
    margin-top: 1.5rem;
    margin-bottom: 4rem;
  }

  .post-header h1 {
    margin: 0 0 0.6rem 0;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }

  .post-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
    font-family: var(--serif);
    font-style: italic;
    letter-spacing: 0;
    background-color: var(--code-bg);
    border-radius: 3px;
    padding: 0.15rem 0.65rem;
  }

  .meta-sep {
    opacity: 0.5;
  }

  .reading-time {
    opacity: 0.9;
  }

  @media (max-width: 520px) {
    .post-header {
      margin-top: 1rem;
      margin-bottom: 3rem;
    }

    .post-header h1 {
      font-size: 1.75rem;
    }
  }
</style>
