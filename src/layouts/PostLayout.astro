---
import '@/styles/global.css'
import type { PostLayoutProps } from '@/types'
import FormattedDate from '@/components/widgets/FormattedDate.astro'
import FootnoteScroll from '@/components/widgets/FootnoteScroll.astro'
import BaseHead from '@/components/layout/BaseHead.astro'
import Header from '@/components/layout/Header.astro'
import Footer from '@/components/layout/Footer.astro'
import TableOfContents from '@/components/ui/TableOfContents.astro'
import LikeButton from '@/components/widgets/LikeButton.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import CopyCode from '@/components/ui/CopyCode.astro'
import GitHubCard from '@/components/ui/GitHubCard.astro'
import ImageOptimizer from '@/components/ui/ImageOptimizer.astro'
import ImageViewer from '@/components/ui/ImageViewer.astro'
import LinkCard from '@/components/ui/LinkCard.astro'
import NeoDBCard from '@/components/ui/NeoDBCard.astro'
import XPOST from '@/components/ui/XPOST.astro'
import GiscusLoader from '@/components/widgets/GiscusLoader.astro'
import { getSortedFilteredPosts } from '@/utils/draft'
import { buildExcerpt } from '@/utils/seo'
import { renderInlineMarkdown } from '@/utils/markdown'

import { themeConfig } from '@/config'

const { title, displayTitle, pubDate, updatedDate, description, hasMath, readingTime, toc, body } =
  Astro.props as PostLayoutProps

const postSlug = Astro.url.pathname.split('/').filter(Boolean).pop() || ''
const sortedPosts = await getSortedFilteredPosts()
const currentPostIndex = sortedPosts.findIndex((post) => post.id === postSlug)
const previousPost = currentPostIndex > 0 ? sortedPosts[currentPostIndex - 1] : undefined
const nextPost =
  currentPostIndex >= 0 && currentPostIndex < sortedPosts.length - 1
    ? sortedPosts[currentPostIndex + 1]
    : undefined
const previousPostLink = previousPost && {
  href: `/${previousPost.id}/`,
  label: previousPost.data.displayTitle || previousPost.data.title
}
const nextPostLink = nextPost && {
  href: `/${nextPost.id}/`,
  label: nextPost.data.displayTitle || nextPost.data.title
}
const ogImage = `/open-graph/${postSlug}.png`
const postDescription = description || buildExcerpt(body || '', themeConfig.site.description)
const headingHtml = displayTitle ? renderInlineMarkdown(displayTitle) : title
const seoTitle = `${title} · ${themeConfig.site.title}`
---

<BaseLayout title={seoTitle} description={postDescription} type="post">
  <BaseHead
    title={title}
    description={postDescription}
    seoTitle={seoTitle}
    ogImage={ogImage}
    pageType="article"
    publishedTime={pubDate}
    modifiedTime={updatedDate}
    slot="head"
  />
  {hasMath && <link rel="stylesheet" href="/katex.min.css" slot="head" />}

  <Header />

  <main class="post-main">
    <article class="prose">
      {themeConfig.post.toc && <TableOfContents toc={toc} />}
      <header class="post-header">
        <h1 set:html={headingHtml} />
        <div class="post-meta">
          <FormattedDate date={pubDate} context="post" />
          {
            themeConfig.post.readingTime && readingTime && (
              <>
                <span class="meta-sep">·</span>
                <span class="reading-time">{readingTime.text}</span>
              </>
            )
          }
        </div>
      </header>
      <slot />
      <LikeButton slug={postSlug} />
    </article>
    <div id="giscus-container"></div>
  </main>

  {/* Post-content widget islands — only shipped on article pages. */}
  <GiscusLoader />
  <ImageOptimizer />
  <CopyCode />
  <GitHubCard />
  <XPOST />
  <NeoDBCard />
  {themeConfig.post.imageViewer && <ImageViewer />}
  {themeConfig.post.linkCard && <LinkCard />}

  <FootnoteScroll />
  {
    themeConfig.general.footer && (
      <Footer previousPostLink={previousPostLink} nextPostLink={nextPostLink} />
    )
  }
</BaseLayout>

<style>
  .post-main {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .post-header {
    margin-top: 1.5rem;
    margin-bottom: 4rem;
  }

  .post-header h1 {
    margin: 0 0 0.6rem 0;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-tertiary);
    font-size: 0.875rem;
    font-family: var(--mono);
    letter-spacing: 0;
  }

  .meta-sep {
    opacity: 0.5;
  }

  .reading-time {
    opacity: 0.9;
  }

  @media (max-width: 520px) {
    .post-header {
      margin-top: 1rem;
      margin-bottom: 3rem;
    }

    .post-header h1 {
      font-size: 1.75rem;
    }
  }
</style>
