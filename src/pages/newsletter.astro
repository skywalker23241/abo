---
import IndexLayout from '../layouts/IndexLayout.astro'
import RssSimple from 'phosphor-astro/RssSimple.astro'
import Envelope from 'phosphor-astro/Envelope.astro'

const pageTitle = '订阅'
const pageDescription = '通过邮件接收新文章'
---

<IndexLayout title={pageTitle} description={pageDescription}>
  <div class="newsletter-page">
    <p class="newsletter-note">只在有新文章时发送，也可以继续使用 RSS。</p>
    <form
      action="https://buttondown.com/api/emails/embed-subscribe/junbo"
      method="post"
      target="popupwindow"
      onsubmit="window.open('https://buttondown.com/junbo', 'popupwindow')"
      class="form"
    >
      <div class="input-wrapper">
        <Envelope width={18} height={18} class="input-icon" />
        <input type="email" name="email" id="bd-email" placeholder="your@email.com" required />
      </div>
      <button type="submit" aria-label="Subscribe">→</button>
      <a
        href="https://rss.beauty/rss?url=https%3A%2F%2Fjackcooper.qzz.io%2Frss.xml"
        target="_blank"
        rel="noopener noreferrer"
        class="rss"
        aria-label="RSS"
        title="RSS"
      >
        <RssSimple width={18} height={18} />
      </a>
    </form>
  </div>
</IndexLayout>

<style>
  .form {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .newsletter-page {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .newsletter-note {
    margin: 0;
    color: var(--text-tertiary);
    font-size: var(--font-size-s);
    line-height: 1.6;
  }

  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    flex: 1;
  }

  .input-icon {
    position: absolute;
    left: 0.75rem;
    color: var(--text-tertiary);
    pointer-events: none;
  }

  input {
    width: 100%;
    padding: 0.6rem 0.75rem 0.6rem 2.4rem;
    border-radius: 0.5rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text-primary);
    font-size: 0.9rem;
    transition: border-color 0.2s ease;
  }

  input:focus {
    outline: none;
    border-color: var(--text-secondary);
  }

  input::placeholder {
    color: var(--text-tertiary);
  }

  button {
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 0.5rem;
    border: 1px solid var(--border);
    background: var(--text-primary);
    color: var(--bg);
    font-size: 1rem;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  button:hover {
    opacity: 0.8;
  }

  .rss {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    color: var(--text-tertiary);
    transition: color 0.2s ease;
  }

  .rss:hover {
    color: var(--text-primary);
  }

  @media (max-width: 420px) {
    .form {
      align-items: stretch;
      flex-wrap: wrap;
    }

    .input-wrapper {
      flex-basis: 100%;
    }
  }
</style>
