---
import IndexLayout from '@/layouts/IndexLayout.astro'

const pageTitle = '笔记'
const pageDescription = '一个公开可读、私有可写的小型 memo zone。'
---

<IndexLayout title={pageTitle} description={pageDescription}>
  <div class="para-notes-page">
    <header class="para-notes-header">
      <div>
        <h1>笔记</h1>
      </div>

      <div class="page-actions">
        <button
          id="memo-search-toggle"
          class="ghost-icon-button"
          type="button"
          aria-label="搜索笔记"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M10.5 4.5a6 6 0 1 0 3.79 10.65l4.28 4.27 1.06-1.06-4.27-4.28A6 6 0 0 0 10.5 4.5Z"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.7"></path>
          </svg>
        </button>
        <button
          id="memo-edit-toggle"
          class="ghost-icon-button edit-icon-button"
          type="button"
          aria-label="编辑笔记"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M4 20h4.2l9.9-9.9a1.7 1.7 0 0 0 0-2.4l-1.8-1.8a1.7 1.7 0 0 0-2.4 0L4 15.8V20Z"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.7"></path>
            <path
              d="m12.8 7 4.2 4.2"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.7"></path>
          </svg>
        </button>
      </div>
    </header>

    <section id="memo-editor" class="editor-panel" hidden>
      <div class="editor-top">
        <h2 id="memo-form-title">新增笔记</h2>
        <button id="memo-cancel-edit" class="ghost-text-button" type="button" hidden>
          Cancel
        </button>
      </div>

      <form id="memo-form" class="editor-form">
        <input id="memo-id" type="hidden" />
        <input id="memo-title" type="text" maxlength="120" placeholder="标题" required />
        <textarea id="memo-content" rows="6" maxlength="4000" placeholder="写一点想法。" required
        ></textarea>
        <div class="editor-actions">
          <button id="memo-submit" class="pill-button" type="submit">Save</button>
        </div>
      </form>
    </section>

    <section class="memo-stream">
      <div id="memo-empty" class="empty-state" hidden>努力加载中......</div>
      <div id="memo-list" class="memo-list" aria-live="polite"></div>
    </section>
  </div>

  <div id="memo-search-modal" class="overlay" hidden>
    <div class="modal-backdrop" data-close-modal="search"></div>
    <div class="overlay-card search-card">
      <div class="modal-head">
        <h2>Search</h2>
        <button class="ghost-text-button" type="button" data-close-modal="search">Close</button>
      </div>
      <input
        id="memo-search-input"
        class="modal-input"
        type="search"
        placeholder="搜索标题或内容"
        autocomplete="off"
      />
    </div>
  </div>

  <div id="memo-passcode-modal" class="overlay" hidden>
    <div class="modal-backdrop" data-close-modal="passcode"></div>
    <div class="overlay-card passcode-card">
      <div class="modal-head">
        <h2>Admin</h2>
        <button class="ghost-text-button" type="button" data-close-modal="passcode">Close</button>
      </div>
      <form id="memo-passcode-form" class="passcode-form">
        <input
          id="memo-passcode-input"
          class="modal-input"
          type="password"
          placeholder="Admin passcode"
          autocomplete="current-password"
          required
        />
      </form>
    </div>
  </div>

  <script src="/scripts/para-notes.js" defer></script>
</IndexLayout>

<style is:global>
  .para-notes-page {
    display: grid;
    gap: 1.5rem;
    animation: memo-page-in 0.58s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .para-notes-page .para-notes-header,
  .para-notes-page .page-actions,
  .para-notes-page .editor-top,
  .para-notes-page .memo-card-head,
  .para-notes-page .memo-actions,
  .para-notes-page .editor-actions,
  .overlay .modal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
  }

  .para-notes-page .para-notes-header {
    align-items: center;
    padding: 0.25rem 0 0.4rem;
  }

  .para-notes-page h1,
  .para-notes-page h2,
  .overlay h2 {
    margin: 0;
    font-weight: 600;
  }

  .para-notes-page h1 {
    font-size: clamp(2rem, 4vw, 2.6rem);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .para-notes-page .memo-time,
  .para-notes-page .empty-state {
    color: var(--text-secondary);
  }

  .para-notes-page .editor-panel,
  .para-notes-page .memo-stream {
    border-top: 1px solid var(--border);
    padding-top: 1.25rem;
    animation: memo-section-in 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .para-notes-page .editor-form,
  .para-notes-page .memo-list {
    display: grid;
    gap: 1rem;
  }

  .para-notes-page .editor-form input,
  .para-notes-page .editor-form textarea,
  .overlay .modal-input {
    width: 100%;
    box-sizing: border-box;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: color-mix(in srgb, var(--bg) 78%, var(--code-bg) 22%);
    color: var(--text-primary);
    padding: 0.95rem 1rem;
    font: inherit;
    line-height: 1.6;
  }

  .para-notes-page .editor-form textarea {
    resize: vertical;
    min-height: 10rem;
  }

  .para-notes-page .editor-form input:focus,
  .para-notes-page .editor-form textarea:focus,
  .overlay .modal-input:focus {
    outline: none;
    border-color: var(--text-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--selection) 80%, transparent);
  }

  .para-notes-page .pill-button,
  .para-notes-page .ghost-icon-button,
  .para-notes-page .ghost-text-button,
  .overlay .pill-button,
  .overlay .ghost-text-button {
    border: 1px solid var(--border);
    color: var(--text-primary);
    font: inherit;
    cursor: pointer;
    position: relative;
    z-index: 2;
    pointer-events: auto;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      background-color 0.18s ease,
      color 0.18s ease;
  }

  .para-notes-page .pill-button,
  .overlay .pill-button {
    padding: 0.52rem 0.9rem;
    border-radius: 999px;
    background: var(--text-primary);
    border-color: var(--text-primary);
    color: var(--bg);
    font-size: 0.95rem;
  }

  .para-notes-page .ghost-icon-button {
    width: 2.2rem;
    height: 2.2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border-radius: 999px;
    background: transparent;
  }

  .para-notes-page .edit-icon-button.is-active {
    background: var(--text-primary);
    border-color: var(--text-primary);
    color: var(--bg);
  }

  .para-notes-page .ghost-icon-button svg {
    width: 0.92rem;
    height: 0.92rem;
  }

  .para-notes-page .ghost-text-button,
  .overlay .ghost-text-button {
    padding: 0.48rem 0.82rem;
    border-radius: 999px;
    background: transparent;
    font-size: 0.94rem;
  }

  .para-notes-page .pill-button:hover,
  .para-notes-page .ghost-icon-button:hover,
  .para-notes-page .ghost-text-button:hover,
  .overlay .pill-button:hover,
  .overlay .ghost-text-button:hover {
    border-color: var(--text-primary);
    transform: translateY(-1px);
  }

  .para-notes-page .ghost-icon-button:hover {
    transform: translateY(-1px) rotate(-8deg);
  }

  .para-notes-page .ghost-text-button,
  .overlay .ghost-text-button {
    color: var(--text-secondary);
  }

  .para-notes-page .danger-button {
    color: #8b2f2f;
  }

  .para-notes-page .pill-button:disabled,
  .para-notes-page .ghost-icon-button:disabled,
  .para-notes-page .ghost-text-button:disabled,
  .overlay .pill-button:disabled,
  .overlay .ghost-text-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  .para-notes-page .page-actions {
    flex-shrink: 0;
  }

  .para-notes-page .editor-top,
  .para-notes-page .memo-card-head {
    align-items: flex-start;
  }

  .para-notes-page .memo-card {
    border: 1px solid var(--border);
    border-radius: 22px;
    padding: 1.2rem 1.25rem;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--bg) 88%, white 12%),
      color-mix(in srgb, var(--bg) 96%, var(--code-bg) 4%)
    );
    transform: translateY(0);
    transition:
      transform 0.22s ease,
      border-color 0.22s ease,
      box-shadow 0.22s ease;
    animation: memo-card-in 0.42s cubic-bezier(0.22, 1, 0.36, 1);
  }

  html.dark .para-notes-page .memo-card {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--bg) 90%, white 2%),
      color-mix(in srgb, var(--bg) 96%, var(--code-bg) 4%)
    );
  }

  .para-notes-page .memo-title {
    font-size: 1.06rem;
  }

  .para-notes-page .memo-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--text-primary) 18%, var(--border) 82%);
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.06);
  }

  .para-notes-page .memo-time {
    margin: 0.25rem 0 0;
    font-size: 0.88rem;
  }

  .para-notes-page .memo-content {
    margin: 1rem 0 0;
    line-height: 1.8;
  }

  .para-notes-page .empty-state {
    padding: 1rem 0;
  }

  .overlay[hidden] {
    display: none;
  }

  .overlay {
    position: fixed;
    inset: 0;
    z-index: 80;
    display: grid;
    place-items: center;
    padding: 1.5rem;
    animation: overlay-fade 0.16s ease-out;
  }

  .overlay .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(18, 18, 18, 0.1);
  }

  .overlay .overlay-card {
    position: relative;
    width: min(100%, 28rem);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 0.95rem 0.95rem 1rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    animation: overlay-pop 0.18s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .overlay .search-card {
    width: min(100%, 30rem);
  }

  .overlay .modal-head {
    align-items: center;
    margin-bottom: 0.7rem;
  }

  .overlay .modal-head h2 {
    font-size: 0.98rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .overlay .passcode-form {
    display: grid;
    gap: 0;
    margin-top: 0.15rem;
  }

  .overlay .modal-input {
    border-radius: 12px;
    background: color-mix(in srgb, var(--bg) 92%, var(--code-bg) 8%);
    padding: 0.82rem 0.9rem;
    min-height: 0;
  }

  .overlay .ghost-text-button {
    padding: 0.38rem 0.7rem;
    font-size: 0.9rem;
    border-color: transparent;
  }

  .overlay .ghost-text-button:hover {
    background: color-mix(in srgb, var(--bg) 70%, var(--code-bg) 30%);
    border-color: transparent;
    transform: none;
  }

  @keyframes memo-page-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes memo-section-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes memo-card-in {
    from {
      opacity: 0;
      transform: translateY(14px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes overlay-fade {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  @keyframes overlay-pop {
    from {
      opacity: 0;
      transform: translateY(6px) scale(0.985);
    }

    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (max-width: 720px) {
    .para-notes-page .para-notes-header {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    .para-notes-page .page-actions,
    .para-notes-page .memo-actions {
      justify-content: flex-start;
      flex-wrap: wrap;
    }

    .para-notes-page .para-notes-header h1 {
      line-height: 1;
      margin: 0;
    }

    .para-notes-page .page-actions {
      align-items: center;
    }

    .para-notes-page .memo-card-head,
    .para-notes-page .editor-top {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
