---
import IndexLayout from '@/layouts/IndexLayout.astro'

const pageTitle = '笔记'
const pageDescription = '一个公开可读、私有可写的小型 memo zone。'
---

<IndexLayout title={pageTitle} description={pageDescription}>
  <div class="para-notes-page">
    <header class="para-notes-header">
      <div>
        <h1>笔记</h1>
      </div>

      <div class="page-actions">
        <button
          id="memo-search-toggle"
          class="ghost-icon-button"
          type="button"
          aria-label="搜索笔记"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M10.5 4.5a6 6 0 1 0 3.79 10.65l4.28 4.27 1.06-1.06-4.27-4.28A6 6 0 0 0 10.5 4.5Z"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.7"></path>
          </svg>
        </button>
        <button
          id="memo-edit-toggle"
          class="ghost-icon-button edit-icon-button"
          type="button"
          aria-label="编辑笔记"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M4 20h4.2l9.9-9.9a1.7 1.7 0 0 0 0-2.4l-1.8-1.8a1.7 1.7 0 0 0-2.4 0L4 15.8V20Z"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.7"></path>
            <path
              d="m12.8 7 4.2 4.2"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.7"></path>
          </svg>
        </button>
      </div>
    </header>

    <section id="memo-editor" class="editor-panel" hidden>
      <div class="editor-top">
        <h2 id="memo-form-title">新增笔记</h2>
        <button id="memo-cancel-edit" class="ghost-text-button" type="button" hidden>
          Cancel
        </button>
      </div>

      <form id="memo-form" class="editor-form">
        <input id="memo-id" type="hidden" />
        <input id="memo-title" type="text" maxlength="120" placeholder="标题" required />
        <textarea id="memo-content" rows="6" maxlength="4000" placeholder="写一点想法。" required
        ></textarea>
        <div class="editor-actions">
          <button id="memo-submit" class="pill-button" type="submit">Save</button>
        </div>
      </form>
    </section>

    <section class="memo-stream">
      <div id="memo-empty" class="empty-state" hidden>努力加载中......</div>
      <div id="memo-list" class="memo-list" aria-live="polite"></div>
    </section>
  </div>

  <div id="memo-search-modal" class="overlay" hidden>
    <div class="modal-backdrop" data-close-modal="search"></div>
    <div class="overlay-card search-card">
      <div class="modal-head">
        <h2>Search</h2>
        <button class="ghost-text-button" type="button" data-close-modal="search">Close</button>
      </div>
      <input
        id="memo-search-input"
        class="modal-input"
        type="search"
        placeholder="搜索标题或内容"
        autocomplete="off"
      />
    </div>
  </div>

  <div id="memo-passcode-modal" class="overlay" hidden>
    <div class="modal-backdrop" data-close-modal="passcode"></div>
    <div class="overlay-card passcode-card">
      <div class="modal-head">
        <h2>Admin</h2>
        <button class="ghost-text-button" type="button" data-close-modal="passcode">Close</button>
      </div>
      <form id="memo-passcode-form" class="passcode-form">
        <input
          id="memo-passcode-input"
          class="modal-input"
          type="password"
          placeholder="Admin passcode"
          autocomplete="current-password"
          required
        />
      </form>
    </div>
  </div>

  <script>
    let paraNotesInitPending = false
    let cleanupParaNotes = () => {}

    function initParaNotes() {
      const page = document.querySelector('.para-notes-page')
      if (!page || page.dataset.paraNotesInit === '1') return
      page.dataset.paraNotesInit = '1'

      const state = {
        notes: [],
        filteredNotes: [],
        authenticated: false,
        editingId: '',
        busy: false,
        keyword: ''
      }

      const storageKey = 'para-notes-admin-passcode'

      const elements = {
        editToggle: document.querySelector('#memo-edit-toggle'),
        searchToggle: document.querySelector('#memo-search-toggle'),
        editor: document.querySelector('#memo-editor'),
        form: document.querySelector('#memo-form'),
        formTitle: document.querySelector('#memo-form-title'),
        memoId: document.querySelector('#memo-id'),
        title: document.querySelector('#memo-title'),
        content: document.querySelector('#memo-content'),
        submit: document.querySelector('#memo-submit'),
        cancelEdit: document.querySelector('#memo-cancel-edit'),
        list: document.querySelector('#memo-list'),
        empty: document.querySelector('#memo-empty'),
        searchModal: document.querySelector('#memo-search-modal'),
        searchInput: document.querySelector('#memo-search-input'),
        passcodeModal: document.querySelector('#memo-passcode-modal'),
        passcodeForm: document.querySelector('#memo-passcode-form'),
        passcodeInput: document.querySelector('#memo-passcode-input')
      }

      let passcodeTimer = 0
      let unlockAttemptId = 0

      function escapeHtml(value) {
        return value
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#39;')
      }

      function formatDate(value) {
        const date = new Date(value)
        if (Number.isNaN(date.getTime())) return ''
        return new Intl.DateTimeFormat('zh-CN', {
          year: 'numeric',
          month: '2-digit',
          day: '2-digit',
          hour: '2-digit',
          minute: '2-digit'
        }).format(date)
      }

      function setStatus(message, type = 'default') {
        if (type === 'error' && elements.empty && state.filteredNotes.length === 0) {
          elements.empty.textContent = message
        }
      }

      function setBusy(busy) {
        state.busy = busy
        ;[
          elements.editToggle,
          elements.searchToggle,
          elements.title,
          elements.content,
          elements.submit,
          elements.cancelEdit,
          elements.passcodeInput,
          elements.searchInput
        ].forEach((control) => {
          if (
            control instanceof HTMLButtonElement ||
            control instanceof HTMLInputElement ||
            control instanceof HTMLTextAreaElement
          ) {
            control.disabled = busy
          }
        })
      }

      function showModal(kind) {
        const modal = kind === 'search' ? elements.searchModal : elements.passcodeModal
        modal?.removeAttribute('hidden')

        window.setTimeout(() => {
          if (kind === 'search' && elements.searchInput instanceof HTMLInputElement) {
            elements.searchInput.focus()
          }

          if (kind === 'passcode' && elements.passcodeInput instanceof HTMLInputElement) {
            elements.passcodeInput.focus()
          }
        }, 0)
      }

      function hideModal(kind) {
        const modal = kind === 'search' ? elements.searchModal : elements.passcodeModal
        if (kind === 'passcode') {
          window.clearTimeout(passcodeTimer)
        }
        modal?.setAttribute('hidden', '')
      }

      function getPasscode() {
        if (elements.passcodeInput instanceof HTMLInputElement) {
          return elements.passcodeInput.value.trim()
        }
        return ''
      }

      async function unlockWithPasscode(passcode) {
        const normalizedPasscode = passcode.trim()
        if (!normalizedPasscode || state.authenticated) return

        const attemptId = ++unlockAttemptId

        try {
          if (elements.passcodeInput instanceof HTMLInputElement) {
            elements.passcodeInput.setAttribute('aria-busy', 'true')
          }

          const response = await fetch('/api/para-notes', {
            method: 'POST',
            headers: {
              'content-type': 'application/json'
            },
            body: JSON.stringify({
              passcode: normalizedPasscode,
              title: 'auth-check',
              content: 'auth-check',
              dryRun: true
            })
          })

          const data = await response.json().catch(() => ({}))
          if (attemptId !== unlockAttemptId) return

          if (!response.ok) {
            if (response.status === 401) return
            throw new Error(typeof data.error === 'string' ? data.error : 'invalid admin passcode')
          }

          if (getPasscode() !== normalizedPasscode) return

          sessionStorage.setItem(storageKey, normalizedPasscode)
          setAuthenticated(true)
          hideModal('passcode')
        } catch (error) {
          if (attemptId !== unlockAttemptId) return
          const message = error instanceof Error ? error.message : '管理员验证失败'
          setStatus(message, 'error')
        } finally {
          if (attemptId === unlockAttemptId && elements.passcodeInput instanceof HTMLInputElement) {
            elements.passcodeInput.removeAttribute('aria-busy')
          }
        }
      }

      function resetForm() {
        state.editingId = ''
        if (elements.formTitle) elements.formTitle.textContent = '新增笔记'
        if (elements.memoId instanceof HTMLInputElement) elements.memoId.value = ''
        if (elements.title instanceof HTMLInputElement) elements.title.value = ''
        if (elements.content instanceof HTMLTextAreaElement) elements.content.value = ''
        if (elements.submit instanceof HTMLButtonElement) elements.submit.textContent = 'Save'
        if (elements.cancelEdit instanceof HTMLButtonElement) elements.cancelEdit.hidden = true
      }

      function beginEdit(note) {
        state.editingId = note.id
        if (elements.formTitle) elements.formTitle.textContent = '编辑笔记'
        if (elements.memoId instanceof HTMLInputElement) elements.memoId.value = note.id
        if (elements.title instanceof HTMLInputElement) elements.title.value = note.title
        if (elements.content instanceof HTMLTextAreaElement) elements.content.value = note.content
        if (elements.submit instanceof HTMLButtonElement) elements.submit.textContent = 'Update'
        if (elements.cancelEdit instanceof HTMLButtonElement) elements.cancelEdit.hidden = false
        elements.editor?.scrollIntoView({ behavior: 'smooth', block: 'start' })
      }

      function applySearch() {
        const keyword = state.keyword.trim().toLowerCase()
        state.filteredNotes = state.notes.filter((note) => {
          if (!keyword) return true
          return `${note.title}\n${note.content}`.toLowerCase().includes(keyword)
        })
        renderNotes()
      }

      function setAuthenticated(nextValue) {
        state.authenticated = nextValue
        elements.editor?.toggleAttribute('hidden', !nextValue)

        if (elements.editToggle instanceof HTMLButtonElement) {
          elements.editToggle.setAttribute('aria-label', nextValue ? '锁定编辑' : '编辑笔记')
          elements.editToggle.classList.toggle('is-active', nextValue)
        }

        if (!nextValue) {
          sessionStorage.removeItem(storageKey)
          if (elements.passcodeInput instanceof HTMLInputElement) {
            elements.passcodeInput.value = ''
          }
          hideModal('passcode')
          resetForm()
        }

        renderNotes()
      }

      function renderNotes() {
        if (!elements.list || !elements.empty) return

        elements.empty.hidden = state.filteredNotes.length !== 0
        if (state.filteredNotes.length === 0) {
          elements.empty.textContent = state.keyword ? '没有匹配的笔记。' : '努力加载中......'
        }
        elements.list.innerHTML = state.filteredNotes
          .map((note) => {
            const actions = state.authenticated
              ? `
              <div class="memo-actions">
                <button class="ghost-text-button" type="button" data-action="edit" data-id="${note.id}">Edit</button>
                <button class="ghost-text-button danger-button" type="button" data-action="delete" data-id="${note.id}">Delete</button>
              </div>
            `
              : ''

            return `
            <article class="memo-card">
              <div class="memo-card-head">
                <div>
                  <h2 class="memo-title">${escapeHtml(note.title)}</h2>
                  <p class="memo-time">${escapeHtml(formatDate(note.updatedAt))}</p>
                </div>
                ${actions}
              </div>
              <p class="memo-content">${escapeHtml(note.content).replaceAll('\n', '<br />')}</p>
            </article>
          `
          })
          .join('')
      }

      async function loadNotes() {
        try {
          const response = await fetch('/api/para-notes')
          const data = await response.json()
          state.notes = Array.isArray(data.notes) ? data.notes : []
          applySearch()
        } catch {
          setStatus('加载笔记失败，请稍后重试。', 'error')
        }
      }

      async function request(method, payload) {
        setBusy(true)

        try {
          const response = await fetch('/api/para-notes', {
            method,
            headers: {
              'content-type': 'application/json'
            },
            body: JSON.stringify(payload)
          })

          const data = await response.json().catch(() => ({}))
          if (!response.ok) {
            throw new Error(typeof data.error === 'string' ? data.error : 'request failed')
          }

          state.notes = Array.isArray(data.notes) ? data.notes : state.notes
          applySearch()
          return data
        } finally {
          setBusy(false)
        }
      }

      elements.searchToggle?.addEventListener('click', () => {
        showModal('search')
      })

      elements.editToggle?.addEventListener('click', () => {
        if (state.authenticated) {
          setAuthenticated(false)
          setStatus('已退出编辑模式。')
          return
        }

        showModal('passcode')
      })

      elements.searchInput?.addEventListener('input', () => {
        if (!(elements.searchInput instanceof HTMLInputElement)) return
        state.keyword = elements.searchInput.value
        applySearch()
      })

      elements.passcodeForm?.addEventListener('submit', (event) => {
        event.preventDefault()
      })

      elements.passcodeInput?.addEventListener('input', () => {
        window.clearTimeout(passcodeTimer)

        if (!getPasscode()) return

        passcodeTimer = window.setTimeout(() => {
          unlockWithPasscode(getPasscode())
        }, 320)
      })

      elements.form?.addEventListener('submit', async (event) => {
        event.preventDefault()

        const passcode = getPasscode() || sessionStorage.getItem(storageKey) || ''
        const title = elements.title instanceof HTMLInputElement ? elements.title.value.trim() : ''
        const content =
          elements.content instanceof HTMLTextAreaElement ? elements.content.value.trim() : ''

        if (!passcode) {
          setStatus('缺少管理员口令。', 'error')
          return
        }

        if (!title || !content) {
          setStatus('标题和内容不能为空。', 'error')
          return
        }

        try {
          if (state.editingId) {
            await request('PUT', { id: state.editingId, title, content, passcode })
            setStatus('笔记已更新。')
          } else {
            await request('POST', { title, content, passcode })
            setStatus('笔记已保存。')
          }

          resetForm()
        } catch (error) {
          const message = error instanceof Error ? error.message : '保存失败'
          setStatus(message, 'error')
        }
      })

      elements.cancelEdit?.addEventListener('click', () => {
        resetForm()
        setStatus('已取消编辑。')
      })

      elements.list?.addEventListener('click', async (event) => {
        const target = event.target
        if (!(target instanceof HTMLElement)) return

        const action = target.dataset.action
        const id = target.dataset.id
        if (!action || !id) return

        const note = state.notes.find((item) => item.id === id)
        if (!note) return

        if (action === 'edit') {
          beginEdit(note)
          return
        }

        if (action === 'delete') {
          const passcode = getPasscode() || sessionStorage.getItem(storageKey) || ''
          if (!passcode) {
            setStatus('缺少管理员口令。', 'error')
            return
          }

          const confirmed = window.confirm(`Delete memo "${note.title}"?`)
          if (!confirmed) return

          try {
            await request('DELETE', { id, passcode })
            if (state.editingId === id) resetForm()
            setStatus('笔记已删除。')
          } catch (error) {
            const message = error instanceof Error ? error.message : '删除失败'
            setStatus(message, 'error')
          }
        }
      })

      const handleDocumentClick = (event) => {
        const target = event.target
        if (!(target instanceof HTMLElement)) return

        const kind = target.dataset.closeModal
        if (kind === 'search' || kind === 'passcode') {
          hideModal(kind)
        }
      }

      const handleDocumentKeydown = (event) => {
        if (event.key !== 'Escape') return
        hideModal('search')
        hideModal('passcode')
      }

      document.addEventListener('click', handleDocumentClick)
      document.addEventListener('keydown', handleDocumentKeydown)

      const rememberedPasscode = sessionStorage.getItem(storageKey)
      if (rememberedPasscode && elements.passcodeInput instanceof HTMLInputElement) {
        elements.passcodeInput.value = rememberedPasscode
        setAuthenticated(true)
        setStatus('已恢复编辑模式。')
      } else {
        setAuthenticated(false)
      }

      loadNotes()

      cleanupParaNotes = () => {
        window.clearTimeout(passcodeTimer)
        unlockAttemptId += 1
        document.removeEventListener('click', handleDocumentClick)
        document.removeEventListener('keydown', handleDocumentKeydown)
        page.dataset.paraNotesInit = '0'
      }
    }

    function scheduleParaNotesInit() {
      if (paraNotesInitPending) return
      paraNotesInitPending = true
      requestAnimationFrame(() => {
        paraNotesInitPending = false
        initParaNotes()
      })
    }

    scheduleParaNotesInit()
    document.addEventListener('astro:after-swap', scheduleParaNotesInit)
    document.addEventListener('astro:page-load', scheduleParaNotesInit)
    document.addEventListener('astro:before-swap', () => {
      cleanupParaNotes()
      cleanupParaNotes = () => {}
    })
  </script>
</IndexLayout>

<style is:global>
  .para-notes-page {
    display: grid;
    gap: 1.5rem;
    animation: memo-page-in 0.58s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .para-notes-page .para-notes-header,
  .para-notes-page .page-actions,
  .para-notes-page .editor-top,
  .para-notes-page .memo-card-head,
  .para-notes-page .memo-actions,
  .para-notes-page .editor-actions,
  .overlay .modal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
  }

  .para-notes-page .para-notes-header {
    align-items: center;
    padding: 0.25rem 0 0.4rem;
  }

  .para-notes-page h1,
  .para-notes-page h2,
  .overlay h2 {
    margin: 0;
    font-weight: 600;
  }

  .para-notes-page h1 {
    font-size: clamp(2rem, 4vw, 2.6rem);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .para-notes-page .memo-time,
  .para-notes-page .empty-state {
    color: var(--text-secondary);
  }

  .para-notes-page .editor-panel,
  .para-notes-page .memo-stream {
    border-top: 1px solid var(--border);
    padding-top: 1.25rem;
    animation: memo-section-in 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .para-notes-page .editor-form,
  .para-notes-page .memo-list {
    display: grid;
    gap: 1rem;
  }

  .para-notes-page .editor-form input,
  .para-notes-page .editor-form textarea,
  .overlay .modal-input {
    width: 100%;
    box-sizing: border-box;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: color-mix(in srgb, var(--bg) 78%, var(--code-bg) 22%);
    color: var(--text-primary);
    padding: 0.95rem 1rem;
    font: inherit;
    line-height: 1.6;
  }

  .para-notes-page .editor-form textarea {
    resize: vertical;
    min-height: 10rem;
  }

  .para-notes-page .editor-form input:focus,
  .para-notes-page .editor-form textarea:focus,
  .overlay .modal-input:focus {
    outline: none;
    border-color: var(--text-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--selection) 80%, transparent);
  }

  .para-notes-page .pill-button,
  .para-notes-page .ghost-icon-button,
  .para-notes-page .ghost-text-button,
  .overlay .pill-button,
  .overlay .ghost-text-button {
    border: 1px solid var(--border);
    color: var(--text-primary);
    font: inherit;
    cursor: pointer;
    position: relative;
    z-index: 2;
    pointer-events: auto;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      background-color 0.18s ease,
      color 0.18s ease;
  }

  .para-notes-page .pill-button,
  .overlay .pill-button {
    padding: 0.52rem 0.9rem;
    border-radius: 999px;
    background: var(--text-primary);
    border-color: var(--text-primary);
    color: var(--bg);
    font-size: 0.95rem;
  }

  .para-notes-page .ghost-icon-button {
    width: 2.2rem;
    height: 2.2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border-radius: 999px;
    background: transparent;
  }

  .para-notes-page .edit-icon-button.is-active {
    background: var(--text-primary);
    border-color: var(--text-primary);
    color: var(--bg);
  }

  .para-notes-page .ghost-icon-button svg {
    width: 0.92rem;
    height: 0.92rem;
  }

  .para-notes-page .ghost-text-button,
  .overlay .ghost-text-button {
    padding: 0.48rem 0.82rem;
    border-radius: 999px;
    background: transparent;
    font-size: 0.94rem;
  }

  .para-notes-page .pill-button:hover,
  .para-notes-page .ghost-icon-button:hover,
  .para-notes-page .ghost-text-button:hover,
  .overlay .pill-button:hover,
  .overlay .ghost-text-button:hover {
    border-color: var(--text-primary);
    transform: translateY(-1px);
  }

  .para-notes-page .ghost-icon-button:hover {
    transform: translateY(-1px) rotate(-8deg);
  }

  .para-notes-page .ghost-text-button,
  .overlay .ghost-text-button {
    color: var(--text-secondary);
  }

  .para-notes-page .danger-button {
    color: #8b2f2f;
  }

  .para-notes-page .pill-button:disabled,
  .para-notes-page .ghost-icon-button:disabled,
  .para-notes-page .ghost-text-button:disabled,
  .overlay .pill-button:disabled,
  .overlay .ghost-text-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  .para-notes-page .page-actions {
    flex-shrink: 0;
  }

  .para-notes-page .editor-top,
  .para-notes-page .memo-card-head {
    align-items: flex-start;
  }

  .para-notes-page .memo-card {
    border: 1px solid var(--border);
    border-radius: 22px;
    padding: 1.2rem 1.25rem;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--bg) 88%, white 12%),
      color-mix(in srgb, var(--bg) 96%, var(--code-bg) 4%)
    );
    transform: translateY(0);
    transition:
      transform 0.22s ease,
      border-color 0.22s ease,
      box-shadow 0.22s ease;
    animation: memo-card-in 0.42s cubic-bezier(0.22, 1, 0.36, 1);
  }

  html.dark .para-notes-page .memo-card {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--bg) 90%, white 2%),
      color-mix(in srgb, var(--bg) 96%, var(--code-bg) 4%)
    );
  }

  .para-notes-page .memo-title {
    font-size: 1.06rem;
  }

  .para-notes-page .memo-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--text-primary) 18%, var(--border) 82%);
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.06);
  }

  .para-notes-page .memo-time {
    margin: 0.25rem 0 0;
    font-size: 0.88rem;
  }

  .para-notes-page .memo-content {
    margin: 1rem 0 0;
    line-height: 1.8;
  }

  .para-notes-page .empty-state {
    padding: 1rem 0;
  }

  .overlay[hidden] {
